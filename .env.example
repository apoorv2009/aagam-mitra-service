ENVIRONMENT=dev
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=meta-llama/llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.5
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=jain-texts
DATABASE_URL=sqlite:///./temple_ai.db
ADMIN_SERVICE_URL=http://localhost:8003
REGISTRATION_SERVICE_URL=http://localhost:8002
RETRIEVAL_LIMIT=4
CHUNK_SIZE_CHARACTERS=800
CHUNK_OVERLAP_CHARACTERS=100
SYNC_TTL_SECONDS=300
